# =============================================================================
# Copilot Dispatch — Environment Variable Reference
# Copy this file to .env/.env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Secret key used to authenticate incoming requests via the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DISPATCH_API_KEY=your-api-key-here

# HMAC secret used to sign outgoing webhook payloads for verification by the
# receiving system.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DISPATCH_WEBHOOK_SECRET=your-webhook-secret-here

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB table used to store run state for webhook correlation and polling.
DYNAMODB_TABLE_NAME=dispatch-runs

# Override DynamoDB endpoint for local development with DynamoDB Local.
# Leave empty or unset to use the real AWS DynamoDB endpoint.
DYNAMODB_ENDPOINT_URL=http://localhost:8100

# -----------------------------------------------------------------------------
# GitHub Configuration
# -----------------------------------------------------------------------------
# Classic PAT with 'repo' scope owned by a Copilot-enabled user.
# Note: In GitHub Actions this is stored as the secret named 'PAT' (not
# 'GITHUB_PAT') because GitHub reserves the GITHUB_ prefix for its own
# built-in secrets. In local environments use GITHUB_PAT as shown below.
GITHUB_PAT=your-github-pat-here

# GitHub organisation or user that owns the copilot-dispatch repository and the
# agent-executor workflow.
GITHUB_OWNER=your-github-owner

# Repository name containing the agent-executor workflow.
GITHUB_REPO=copilot-dispatch

# Workflow file name that runs the Copilot agent (relative to .github/workflows/).
GITHUB_WORKFLOW_ID=agent-executor.yml

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Deployment environment: local | test | production
APP_ENV=local

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
