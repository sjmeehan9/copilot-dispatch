# =============================================================================
# Copilot Dispatch — Test Environment Variables
# Used by pytest when running the test suite locally and in CI.
# These are safe dummy values — no real credentials.
# =============================================================================

# API Configuration
DISPATCH_API_KEY=test-api-key-12345
DISPATCH_WEBHOOK_SECRET=test-webhook-secret-12345

# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
DYNAMODB_TABLE_NAME=dispatch-runs-test
DYNAMODB_ENDPOINT_URL=http://localhost:8100

# GitHub Configuration — non-functional test values
GITHUB_PAT=test-pat-not-real
GITHUB_OWNER=test-owner
GITHUB_REPO=test-repo
GITHUB_WORKFLOW_ID=agent-executor.yml

# Application Configuration
APP_ENV=test
LOG_LEVEL=DEBUG
